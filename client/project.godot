; Engine configuration file.
; It is best edited using the Godot editor.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pocket Pet Remake Client"
run/main_scene="res://scenes/bootstrap/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://autoload/game_state.gd"
MessageRouter="*res://autoload/message_router.gd"
HttpClient="*res://autoload/http_client.gd"
NetClient="*res://autoload/net_client.gd"
App="*res://autoload/app.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
environment/defaults/default_clear_color=Color(0.0745098, 0.101961, 0.152941, 1)
