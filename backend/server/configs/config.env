# Runtime repository mode.
# Keep `memory` until PostgreSQL and Redis are ready.
PP_REPOSITORY_MODE=memory

# HTTP and auth runtime.
PP_HTTP_ADDR=:8080
PP_JWT_SECRET=change-me
PP_ACCESS_TOKEN_TTL_SECONDS=7200
PP_WS_TOKEN_TTL_SECONDS=60
PP_HEARTBEAT_INTERVAL_SECONDS=10
PP_HEARTBEAT_TIMEOUT_SECONDS=30

# PostgreSQL runtime.
# Switch `PP_REPOSITORY_MODE` to `postgres_redis` after the service is online.
PP_POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/pocket_pet?sslmode=disable
PP_POSTGRES_MAX_OPEN_CONNS=20
PP_POSTGRES_MAX_IDLE_CONNS=10
PP_POSTGRES_CONN_MAX_LIFETIME_SECONDS=1800

# Redis runtime.
PP_REDIS_ADDR=127.0.0.1:6379
PP_REDIS_PASSWORD=
PP_REDIS_DB=0
PP_REDIS_KEY_PREFIX=pocket_pet

# Demo account for the current skeleton.
PP_DEMO_ACCOUNT=demo
PP_DEMO_PASSWORD=demo123
PP_DEMO_PLAYER_NAME=DemoTrainer
PP_DEMO_ACCOUNT_ID=1
PP_DEMO_PLAYER_ID=10001
